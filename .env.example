# Notifications — Block Blast Autopilot
# Copier ce fichier en .env et remplir les champs voulus.
# Laisser vide ("") pour désactiver ce canal silencieusement.

# Discord : webhook URL dans Paramètres du channel → Intégrations → Webhooks
DISCORD_WEBHOOK_URL=

# Telegram : token du bot (via @BotFather) + chat_id (via @getidsbot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stats de session envoyées toutes les N tours (0 = désactiver)
NOTIFY_STATS_EVERY_N_TURNS=20
